<%- include('../partials/head', { title: 'Administration' }) %>
<%- include('../partials/header') %>

<body>
  <section class="auth-wrap admin-login">
</body>
<section class="auth-wrap">
  <div class="auth-card">
    <center><h1>Administration</h1></center>
    <center><p>Cet accès est restreint, veuillez saisir le mot de passe.</p></center>
    <form action="/administration/login" method="POST" class="stack-form">
      
      <label class="field">
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <button class="btn btn-primary" type="submit">Se connecter</button>
    </form>
  </div>
</section>
<%- include('../partials/footer') %>
